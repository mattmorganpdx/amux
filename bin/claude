#!/usr/bin/env bash
# amux claude wrapper - injects hooks and session tracking
#
# When running inside an amux terminal (AMUX_SURFACE_ID is set), this wrapper
# intercepts `claude` invocations to inject --session-id and --settings flags
# so that Claude Code hooks fire back into amux for notifications/status.
# Outside amux, it passes through to the real claude binary unchanged.

# Find the real claude binary, skipping our own directory.
find_real_claude() {
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$self_dir" ]] && continue
        [[ -x "$d/claude" ]] && printf '%s' "$d/claude" && return 0
    done
    return 1
}

# Detect platform-specific CLI binary name.
if [[ "$(uname -s)" == "Linux" ]]; then
    AMUX_CLI_NAME="amux-cli"
else
    AMUX_CLI_NAME="amux"
fi

# Return 0 only when AMUX_SOCKET_PATH points to a live amux socket.
amux_socket_available() {
    local socket="${AMUX_SOCKET_PATH:-}"
    [[ -n "$socket" && -S "$socket" ]] || return 1

    local self_dir amux_bin
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    amux_bin="$self_dir/$AMUX_CLI_NAME"
    [[ -x "$amux_bin" ]] || amux_bin="$(command -v "$AMUX_CLI_NAME" || true)"
    [[ -n "$amux_bin" ]] || return 1

    # Keep stale/hung socket checks bounded so claude startup does not block
    # behind the CLI default timeout (15s).
    AMUX_CLI_RESPONSE_TIMEOUT_SEC=0.75 \
        "$amux_bin" --socket "$socket" ping >/dev/null 2>&1
}

# Pass through if not in an amux terminal, hooks are disabled, or the amux
# socket is unavailable (stale env / app not running).
IN_AMUX=0
if [[ -n "${AMUX_SURFACE_ID:-}" ]]; then
    IN_AMUX=1
fi

if [[ "$IN_AMUX" == "0" || "${AMUX_CLAUDE_HOOKS_DISABLED:-}" == "1" ]] || ! amux_socket_available; then
    # In amux-launched shells, preserve old behavior and always clear nested
    # Claude session markers, even when we must pass through due to stale socket.
    if [[ "$IN_AMUX" == "1" ]]; then
        unset CLAUDECODE
    fi
    REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }
    exec "$REAL_CLAUDE" "$@"
fi

# Find real claude.
REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }

# Pass through subcommands that don't support session/hook flags.
case "${1:-}" in
    mcp|config|api-key) exec "$REAL_CLAUDE" "$@" ;;
esac

# Unset CLAUDECODE to avoid "nested session" detection — amux terminals are
# independent sessions even when the parent shell was launched from Claude Code.
unset CLAUDECODE

# Check if the user already specified a session/resume flag.
# If so, don't inject our own --session-id (it would conflict).
SKIP_SESSION_ID=false
for arg in "$@"; do
    case "$arg" in
        --resume|--resume=*|--session-id|--session-id=*|--continue|-c)
            SKIP_SESSION_ID=true
            break
            ;;
    esac
done

# Build hooks settings JSON.
# Claude Code merges --settings additively with the user's own settings.json.
HOOKS_JSON="{\"hooks\":{\"SessionStart\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"$AMUX_CLI_NAME claude-hook session-start\",\"timeout\":10}]}],\"Stop\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"$AMUX_CLI_NAME claude-hook stop\",\"timeout\":10}]}],\"Notification\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"$AMUX_CLI_NAME claude-hook notification\",\"timeout\":10}]}]}}"

if [[ "$SKIP_SESSION_ID" == true ]]; then
    exec "$REAL_CLAUDE" --settings "$HOOKS_JSON" "$@"
else
    SESSION_ID="$(uuidgen | tr '[:upper:]' '[:lower:]')"
    exec "$REAL_CLAUDE" --session-id "$SESSION_ID" --settings "$HOOKS_JSON" "$@"
fi
